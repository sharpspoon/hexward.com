<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | {{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/blog/feed.xml">

    <!-- Open Graph -->
    <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description or site.description }}">

    <style>
        :root {
            --bg: #d9d9d9;
            --panel: #efefef;
            --text: #111111;
            --muted: #3a3a3a;
            --line: #7a7a7a;
            --blue: #0000cc;
            --green: #008000;
            --red: #cc0000;
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text);
            font-family: "Courier New", Courier, monospace;
            line-height: 1.6;
        }

        a { color: var(--blue); }
        a:hover, a:focus { color: var(--red); }

        .wrap { max-width: 980px; margin: 0 auto; padding: 1.25rem; }

        header {
            border: 1px solid var(--line);
            background: #f7f7f7;
            margin-top: 1rem;
        }

        .brand {
            border-bottom: 1px solid var(--line);
            padding: 0.75rem 1rem;
            color: var(--green);
            font-weight: bold;
            letter-spacing: 0.04em;
        }

        .brand a { color: var(--green); text-decoration: none; }

        nav { padding: 0.75rem 1rem; }

        nav ul {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin: 0;
            padding: 0;
        }

        nav a {
            text-decoration: none;
            border: 1px solid var(--line);
            padding: 0.2rem 0.5rem;
            display: inline-block;
        }

        main {
            margin-top: 1.25rem;
            border: 1px solid var(--line);
            background: #fafafa;
            padding: 1.5rem;
        }

        h1, h2, h3 { margin: 0 0 0.75rem; line-height: 1.3; }
        h1 { color: var(--blue); font-size: 1.65rem; }
        h2 { color: #000; font-size: 1.35rem; margin-top: 1.5rem; }
        h3 { color: var(--green); font-size: 1.1rem; margin-top: 1.2rem; }

        p { margin: 0 0 0.9rem; }

        article.post-body p,
        article.post-body ul,
        article.post-body ol { margin-bottom: 1rem; }

        article.post-body ul,
        article.post-body ol { padding-left: 1.4rem; }

        article.post-body code {
            background: #000;
            color: #00ff00;
            padding: 0.1rem 0.3rem;
            font-size: 0.9em;
        }

        article.post-body pre {
            background: #000;
            border: 1px solid var(--line);
            color: #00ff00;
            padding: 0.85rem;
            overflow-x: auto;
            margin: 0.8rem 0 1rem;
        }

        article.post-body pre code {
            background: transparent;
            padding: 0;
        }

        article.post-body blockquote {
            border-left: 3px solid var(--line);
            margin: 1rem 0;
            padding: 0.3rem 0 0.3rem 1rem;
            color: var(--muted);
        }

        .post-meta {
            color: var(--muted);
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
            border-bottom: 1px solid var(--line);
            padding-bottom: 0.75rem;
        }

        .post-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .post-list li {
            border: 1px solid var(--line);
            background: var(--panel);
            padding: 0.9rem;
            margin-bottom: 0.9rem;
        }

        .post-list h2 { margin: 0 0 0.3rem; font-size: 1.15rem; }
        .post-list h2 a { text-decoration: none; }
        .post-list .date { color: var(--muted); font-size: 0.9rem; }
        .post-list p { margin: 0.5rem 0 0; }

        .post-footer {
            border-top: 1px solid var(--line);
            margin-top: 2rem;
            padding-top: 1rem;
            color: var(--muted);
        }

        footer {
            margin: 1rem 0 1.5rem;
            border: 1px solid var(--line);
            background: #f0f0f0;
            padding: 0.75rem 1rem;
            color: var(--muted);
        }

        @media (max-width: 720px) {
            h1 { font-size: 1.45rem; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <header>
            <div class="brand"><a href="/">HEXWARD CONSULTING</a> // BLOG</div>
            <nav aria-label="Primary navigation">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/#services">Services</a></li>
                    <li><a href="/#about">About</a></li>
                    <li><a href="/blog/">Blog</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
            </nav>
        </header>

        <main>
            {{ content | safe }}
        </main>

        <footer>
            <p>&copy; 2026 Hexward Consulting. All rights reserved. <a href="/blog/feed.xml">RSS</a></p>
        </footer>
    </div>
</body>
</html>
