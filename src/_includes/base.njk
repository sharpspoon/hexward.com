<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | {{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="icon" href="/logo.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/blog/feed.xml">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z5TX31BKXN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Z5TX31BKXN');
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description or site.description }}">

</head>
<body class="blog-page">
        <header>
            <div class="wrap">
            <div class="brand"><a href="/"><img src="/logo.svg" alt="Hexward logo" class="brand-logo">Hexward Consulting</a></div>
            <nav aria-label="Primary navigation">
                <ul>
                    <li><a href="/#services">Services</a></li>
                    <li><a href="/case-studies.html">Work</a></li>
                    <li><a href="/blog/">Blog</a></li>
                    <li><a href="/#about">About</a></li>
                    <li><a href="/#contact">Contact</a></li>
                    <li><a href="https://www.linkedin.com/in/wardro/" class="social-link" aria-label="LinkedIn">LinkedIn</a></li>
                    <li><a href="https://github.com/sharpspoon" class="social-link" aria-label="GitHub">GitHub</a></li>
                </ul>
            </nav>
            </div>
        </header>

        <main class="blog-main">
            {{ content | safe }}
        </main>

        <footer>
            <div class="wrap">
                <div class="footer-content">
                    <p>&copy; 2026 Hexward Consulting. All rights reserved. US-based &middot; Fully Remote</p>
                    <div class="footer-links">
                        <a href="https://www.linkedin.com/in/wardro/">LinkedIn</a>
                        <a href="https://github.com/sharpspoon">GitHub</a>
                        <a href="mailto:robin.ward@hexward.com">Email</a>
                        <a href="/blog/feed.xml">RSS</a>
                    </div>
                </div>
            </div>
        </footer>
</body>
</html>
