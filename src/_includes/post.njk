---
layout: base.njk
---
<article class="post-body">
    <h1>{{ title }}</h1>
    <div class="post-meta">
        {{ page.date | readableDate }}{% if tags %} &middot; {{ tags | join(", ") }}{% endif %}
    </div>

    {{ content | safe }}

    <div class="post-footer">
        <p>&mdash; Robin Ward</p>
        <p><a href="/blog/">&larr; All posts</a></p>
        <p>Need help with something like this? <a href="/#contact">Get in touch</a>.</p>
    </div>
</article>
